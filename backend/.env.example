# .env — Copy this to .env and fill in your values
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=48

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Database (SQLite for demo, swap to PostgreSQL in production)
DATABASE_URL=sqlite+aiosqlite:///./crisis_response.db

# Firebase (for push notifications)
# Download serviceAccountKey.json from Firebase Console → Project Settings → Service Accounts
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json

# Admin credentials (for demo — use proper IAM in production)
ADMIN_EMAIL=admin@crisisresponse.gov
ADMIN_PASSWORD=SecureAdmin2024!

# App Config
APP_NAME=Crisis Response API
APP_VERSION=1.0.0
DEBUG=true
